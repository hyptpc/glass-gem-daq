# ===== Oscilloscope connection =====
# 使用するオシロのIPアドレス（必須）
OSC_IP=192.168.20.92

# デフォルトで使うチャンネル（省略可）
OSC_CHANNEL=CH1

# データ開始/終了インデックス（省略可）
OSC_START_INDEX=1
OSC_STOP_INDEX=10000

# VISAタイムアウト (ms)（省略可）
OSC_TIMEOUT_MS=30000

# 波形などの出力ディレクトリ（省略可）
SCOPE_OUTDIR=scope_output


# ===== Discord webhook (任意) =====
# CLIキャプチャ(test.py)で使うDiscordのWebhook URL
# 通知が不要な場合は未設定でOK
WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

