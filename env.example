# ===== Oscilloscope connection =====
# Oscilloscope IP address (required)
OSC_IP=192.168.20.92

# Default channel (optional)
OSC_CHANNEL=CH1

# Data start/stop index (optional)
OSC_START_INDEX=1
OSC_STOP_INDEX=10000

# VISA timeout in ms (optional)
OSC_TIMEOUT_MS=30000

# Output directory for saved waveforms (optional, default: outputs/)
OUTPUT_DIR=outputs


# ===== Camera (optional) =====
# MJPEG stream URL for live camera in UI (e.g. Raspberry Pi mjpg-streamer).
# Unset = camera section hidden.
# CAMERA_STREAM_URL=http://192.168.20.32:8080/?action=stream

# ===== Discord webhook (optional) =====
# Discord webhook URL for CLI capture (test.py)
# Leave unset if you don't need notifications
WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

